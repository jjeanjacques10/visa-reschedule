# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# DynamoDB
DYNAMODB_USERS_TABLE=visa-reschedule-users
DYNAMODB_APPOINTMENTS_TABLE=visa-reschedule-appointments
DYNAMODB_ENDPOINT_URL=http://localhost:4566  # For localstack

# SQS
APPOINTMENT_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/visa-appointments

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Flask
FLASK_DEBUG=true
FLASK_PORT=5000
