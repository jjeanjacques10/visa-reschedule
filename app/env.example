# AWS Configuration
# For LocalStack: use any non-empty dummy values (e.g. AWS_ACCESS_KEY_ID=test).
# For real AWS: use your IAM credentials.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# DynamoDB
DYNAMODB_USERS_TABLE=visa-reschedule-users
DYNAMODB_USERS_TELEGRAM_INDEX=telegram_id-index
DYNAMODB_APPOINTMENTS_TABLE=visa-reschedule-appointments
# Leave DYNAMODB_ENDPOINT_URL empty to use real AWS; set it for LocalStack.
DYNAMODB_ENDPOINT_URL=

# SQS
# Leave APPOINTMENT_QUEUE_URL empty to use real AWS; set it for LocalStack.
APPOINTMENT_QUEUE_URL=

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Flask
FLASK_DEBUG=false
FLASK_PORT=5000

# Runtime
# ENVIRONMENT=dev enables visible browser by default (SELENIUM_HEADLESS can override).
ENVIRONMENT=prod
# Optional override (true/false). If unset, defaults to false in dev and true otherwise.
# SELENIUM_HEADLESS=true
